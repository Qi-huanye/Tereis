*.log
*.tmp
*.temp
*.stackdump

# IDE and editor user files
.idea/
*.suo
*.user
*.userossc
*.vcxproj.user
*.code-workspace

# VS Code: keep shared project settings, ignore local history/cache
.vscode/*.log
.vscode/*.tmp
.vscode/.ropeproject/

# OS files
.DS_Store
Thumbs.db
Desktop.ini
