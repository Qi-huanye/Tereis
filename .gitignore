# Build outputs
/.vscode-build/
/build/
/bin/
/obj/
/out/
/dist/

# Executables and libraries
*.exe
*.dll
*.lib
*.a
*.so
*.dylib

# Object and intermediate files
*.o
*.obj
*.pch
*.pdb
*.ilk
*.idb
