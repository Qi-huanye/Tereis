{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build Tetris MinGW",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\build-mingw.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "run Tetris MinGW",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\build-mingw.ps1",
                "-Run"
            ],
            "group": "test",
            "problemMatcher": "$gcc"
        }
    ]
}
